{
  "name": "sidebearing-trim",
  "version": "0.2.0",
  "description": "Trim line-start sidebearing using font metrics for vanilla JS and React.",
  "homepage": "https://sidebearing-trim.js.org/",
  "repository": {
    "type": "git",
    "url": "https://github.com/peksi/sidebearing-trim.git"
  },
  "bugs": {
    "url": "https://github.com/peksi/sidebearing-trim/issues"
  },
  "license": "MIT",
  "keywords": [
    "typography",
    "font",
    "sidebearing",
    "react",
    "dom"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "LICENCE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.ts --format esm,cjs --dts --clean && node ./scripts/copy-styles.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "opentype.js": "^1.3.4"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.2.0",
    "jsdom": "^24.1.3",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
